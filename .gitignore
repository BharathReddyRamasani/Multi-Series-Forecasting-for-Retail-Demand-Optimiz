# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# ── Node / Frontend ──
node_modules/
dist/
*.tsbuildinfo
.vite/

# ── Environment & Secrets ──
.env
.env.local
.env.*.local
*.pem
*.key

# ── Databases (large binary, keep on disk only) ──
*.db
*.sqlite
*.sqlite3

# ── Model binaries (large files — keep on disk, train via train_v2.py) ──
models/**/*.pkl
models/**/*.h5
models/**/*.joblib
models/**/*.bin

# ── Keep small model metadata for reproducibility ──
!models/**/*_metrics.csv
!models/**/*_params.json
!models/**/*_feature_importance.csv
!models/**/*_cv_results*.csv

# ── Logs & OS ──
*.log
.DS_Store
Thumbs.db

# ── Backend generated static ──
backend/static/

# ── IDE / editor ──
.vscode/
.idea/

# ── Lint caches ──
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
